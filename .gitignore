__pycache__/
*.py[cod]
*.pyo
*.pyd
*.pyc

# -----------------------------------------------
# Environment & Secrets
# -----------------------------------------------
.env
.env.*
*.env

# -----------------------------------------------
# Virtual environments
# -----------------------------------------------
.venv/
venv/
env/
ENV/

# -----------------------------------------------
# AFL Cache
# Raw scraped pages are NOT committed (~1,800 files).
# The parser saves them WITHOUT a .html extension
# (dots are normalised to underscores), so the
# patterns below target the actual filenames.
# The optimised Parquet panel (~0.1 MB) IS committed
# so collaborators can run EDA scripts without re-scraping.
# -----------------------------------------------
afl_cache/match_*
afl_cache/season_*
# Explicitly allow the panel cache
!afl_cache/raw_panel.parquet

